# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ==============================================================================
# APPLICATION SETTINGS
# ==============================================================================
DEBUG=false
ENVIRONMENT=development
APP_NAME="Sondra Keys Legal QA"
APP_VERSION=0.1.0

# ==============================================================================
# AZURE - Content Understanding
# ==============================================================================
AZURE_CONTENT_UNDERSTANDING_ENDPOINT=https://YOUR_REGION.api.cognitive.microsoft.com/
AZURE_CONTENT_UNDERSTANDING_KEY=your-api-key-here

# ==============================================================================
# AZURE - Cognitive Search (Vector Storage)
# ==============================================================================
AZURE_SEARCH_SERVICE_NAME=your-search-service-name
AZURE_SEARCH_API_KEY=your-search-api-key
AZURE_SEARCH_INDEX_NAME=legal-documents

# ==============================================================================
# AZURE - Blob Storage (Document Storage)
# ==============================================================================
AZURE_BLOB_ACCOUNT_NAME=your-storage-account-name
AZURE_BLOB_ACCOUNT_KEY=your-storage-account-key
AZURE_BLOB_CONTAINER_NAME=documents

# ==============================================================================
# AZURE - OpenAI (Q&A Generation)
# ==============================================================================
AI_OPENAI_API_KEY=your-openai-api-key
AI_OPENAI_ENDPOINT=https://YOUR_RESOURCE_NAME.openai.azure.com/
AI_OPENAI_DEPLOYMENT_NAME=gpt-4
AI_OPENAI_API_VERSION=2024-02-15-preview

# ==============================================================================
# AI/ML SETTINGS
# ==============================================================================
AI_CHUNK_SIZE=1024
AI_CHUNK_OVERLAP=20

# ==============================================================================
# DATABASE
# ==============================================================================
DB_DATABASE_URL=sqlite:///./legal_qa.db
# For PostgreSQL: postgresql://user:password@localhost/database_name
DB_DATABASE_ECHO=false

# ==============================================================================
# SECURITY
# ==============================================================================
SECURITY_API_KEY=your-secure-api-key-here
SECURITY_MAX_FILE_SIZE_MB=50
SECURITY_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ==============================================================================
# LOGGING
# ==============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==============================================================================
# GITHUB ACTIONS / AZURE DEPLOYMENT
# ==============================================================================
# These are typically set as GitHub Secrets and Variables
# AZURE_CLIENT_ID - Set in GitHub Secrets (for OIDC)
# AZURE_TENANT_ID - Set in GitHub Secrets/Variables (for OIDC)
# AZURE_SUBSCRIPTION_ID - Set in GitHub Secrets/Variables (for OIDC)
# AZURE_RESOURCE_GROUP - Set as GitHub Variable
# AZURE_REGION - Set as GitHub Variable (e.g., eastus)
